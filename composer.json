{
    "name": "constelation/shared",
    "description": "Shared contracts, DTOs, events and libraries for Constelation microservices",
    "type": "library",
    "keywords": ["constelation", "shared", "contracts", "events", "microservices"],
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "ramsey/uuid": "^4.7",
        "php-amqplib/php-amqplib": "^3.6",
        "illuminate/support": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Constelation\\Shared\\": "./",
            "Constelation\\Shared\\Core\\": "core/src/",
            "Constelation\\Shared\\Auth\\": "core/src/Auth/",
            "Constelation\\Shared\\Logging\\": "core/src/Logging/",
            "Constelation\\Shared\\Queue\\": "core/src/Queue/",
            "Constelation\\Shared\\Utils\\": "core/src/Utils/",
            "Constelation\\Shared\\Support\\": "core/src/Support/",
            "Constelation\\Shared\\Traits\\": "core/src/Traits/",
            "Constelation\\Shared\\Validation\\": "core/src/Validation/",
            "Constelation\\Shared\\Events\\": "core/src/Events/"
        }
    },
    "files": [
        "helpers.php"
    ],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
